# ===========================
# Configuração do Servidor
# ===========================
PORT=3001
NODE_ENV=development

# ===========================
# Microsoft Graph API (OAuth 2.0)
# Será configurado na etapa de integração
# ===========================
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_REDIRECT_URI=http://localhost:3001/api/auth/callback

# ===========================
# Microsoft Lists (SharePoint)
# ===========================
MS_SITE_ID=
MS_LIST_ID=

# ===========================
# Relatórios PDF / Outlook
# ===========================
MS_SENDER_EMAIL=
